{
  "info": {
    "name": "Challenge Software Backend API",
    "description": "Collection for testing the Challenge Software Backend API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('token', response.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Home",
      "item": [
        {
          "name": "Test Endpoint",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/test",
              "host": ["{{baseUrl}}"],
              "path": ["test"]
            }
          }
        }
      ]
    },
    {
      "name": "Cities",
      "item": [
        {
          "name": "Get All Cities",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cities",
              "host": ["{{baseUrl}}"],
              "path": ["cities"]
            }
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "Get All Companies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/companies",
              "host": ["{{baseUrl}}"],
              "path": ["companies"]
            }
          }
        },
        {
          "name": "Get Company by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/companies/1",
              "host": ["{{baseUrl}}"],
              "path": ["companies", "1"]
            }
          }
        },
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Example Company",
                  "type": "text"
                },
                {
                  "key": "responsibleName",
                  "value": "John Doe",
                  "type": "text"
                },
                {
                  "key": "cityId",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "contact@example.com",
                  "type": "text"
                },
                {
                  "key": "segmentId",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "status",
                  "value": "true",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/companies",
              "host": ["{{baseUrl}}"],
              "path": ["companies"]
            }
          }
        },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Updated Company",
                  "type": "text"
                },
                {
                  "key": "responsibleName",
                  "value": "Jane Doe",
                  "type": "text"
                },
                {
                  "key": "cityId",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "updated@example.com",
                  "type": "text"
                },
                {
                  "key": "segmentId",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "status",
                  "value": "false",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/companies/1",
              "host": ["{{baseUrl}}"],
              "path": ["companies", "1"]
            }
          }
        },
        {
          "name": "Delete Company",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/companies/1",
              "host": ["{{baseUrl}}"],
              "path": ["companies", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Segments",
      "item": [
        {
          "name": "Get All Segments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/segments",
              "host": ["{{baseUrl}}"],
              "path": ["segments"]
            }
          }
        },
        {
          "name": "Get Segment by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/segments/1",
              "host": ["{{baseUrl}}"],
              "path": ["segments", "1"]
            }
          }
        },
        {
          "name": "Create Segment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "New Segment",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/segments",
              "host": ["{{baseUrl}}"],
              "path": ["segments"]
            }
          }
        },
        {
          "name": "Update Segment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Updated Segment",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/segments/1",
              "host": ["{{baseUrl}}"],
              "path": ["segments", "1"]
            }
          }
        },
        {
          "name": "Delete Segment",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/segments/1",
              "host": ["{{baseUrl}}"],
              "path": ["segments", "1"]
            }
          }
        }
      ]
    }
  ]
}